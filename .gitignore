# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules
jspm_packages

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

dist/
!src/js/vendor/**/dist

src/build

.vscode
.idea

.DS_Store

.cache

.env
*.env

# Local-only notes (internal TODOs, deploy checklists, scratch files)
# Anything matching *.local.md is treated as personal and never committed.
*.local.md
NOTES.local.md

# SQLite databases + WAL files
web-server/data/*.db
web-server/data/*.db-wal
web-server/data/*.db-shm

# Local blob store (content-addressed PNGs)
web-server/data/blobs/
